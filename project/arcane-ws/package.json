{
  "name": "ln-ws-chat",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "NODE_ENV=development bun run --env-file=.env.test.local --watch src/index.ts",
    "start": "NODE_ENV=production bun --env-file=.env  dist/index.js",
    "dev:start": "NODE_ENV=development bun --env-file=.env.test.local  dist/index.js",
    "build": "bun build src/index.ts --target bun --outdir ./dist",
    "build:fe": "bun build --outfile=[bundle].js public/index.tsx",
    "db:generate:dev": "bun --env-file=.env.test.local drizzle-kit generate",
    "db:push:dev": "bun --env-file=.env.test.local drizzle-kit push",
    "db:migrate:dev": "bun --env-file=.env.test.local drizzle-kit migrate",
    "test": "bun --env-file=.env.test.local test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "drizzle-kit": "^0.31.9"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/jwt": "^1.4.1",
    "@elysiajs/static": "^1.4.7",
    "@neondatabase/serverless": "^1.0.2",
    "drizzle-orm": "^0.45.1",
    "drizzle-typebox": "^0.3.3",
    "elysia": "^1.4.25",
    "postgres": "^3.4.8"
  },
  "overrides": {
    "@sinclair/typebox": "0.32.4"
  }
}
